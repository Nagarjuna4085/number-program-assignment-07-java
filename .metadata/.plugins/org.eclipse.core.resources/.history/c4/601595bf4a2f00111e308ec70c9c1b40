package javaprograms;

import java.util.ArrayList;
import java.util.Scanner;

public class KeithNumber {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number:");
        int n = sc.nextInt();
        String s = String.valueOf(n);
        int len = s.length();
        
        ArrayList<Integer> nums = new ArrayList<>();
        int currentSum = 0;

        // 1. Fill the initial window with digits
        for (int i = 0; i < len; i++) {
            int digit = s.charAt(i) - '0';
            nums.add(digit);
            currentSum += digit;
        }

        // 2. The Sliding Window Logic
        // We continue as long as the last calculated sum is less than n
        while (currentSum < n) {
            nums.add(currentSum); // Add the newest sum to the end
            nums.remove(0);       // Remove the oldest digit from the front
            
            // Calculate the next sum from the current window
            int newSum = 0;
            for (int j = 0; j < nums.size(); j++) {
                newSum += nums.get(j);
            }
            currentSum = newSum;
        }

        // 3. Final Check
        if (currentSum == n) {
            System.out.println(n + " is a Keith Number");
        } else {
            System.out.println(n + " is not a Keith Number");
        }
        
        sc.close();
    }
}